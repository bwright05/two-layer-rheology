ax1.plot(x_hat, profile_c_bot, 'C3--', label='L=2 bottom (n=3)')
ax1.set_xlabel(r'$\hat{x}$')
ax1.set_ylabel(r'$v_x$ (m/yr)')
ax1.set_title('Full velocity profile')
ax1.legend(fontsize=9)

