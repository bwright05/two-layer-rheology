ax2.plot(x_hat, profile_c_bot, 'C3--', label='L=2 bottom (n=3)')
ax2.set_xlabel(r'$\hat{x}$')
ax2.set_ylabel(r'$v_x$ (m/yr)')
ax2.set_xlim(0.7, 0.8)
ax2.set_title('Zoomed in')
ax2.legend(fontsize=9)

