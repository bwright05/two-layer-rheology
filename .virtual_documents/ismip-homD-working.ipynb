print(f'{'L (km)':>8s}', end='') #L (km) 

#print layer 1
print(f"  {'L=' + str(layer_counts) + ' surf':>12s}", end="")
print()
print('-'*70) #adding another line 

#printing the data
print(f'{Lx/1e3:8.0f}', end='', flush=True) #prints the wavelenght/domain 
nx = min(max(20, int(40*80e3/Lx)), 80) #makes it equal to 40 (drops of e3) 
u_surf = profile_ssa
print(f' {np.max(u_surf):12.4f}', end='', flush=True) #prints the maximum of the velocity profile 
print()
print('-'*70)
print(f' {'Velocity size', profile_ssa.size}') #prints size of the velocity array 


fig, axes = plt.subplots()
plt.plot(x_hat, profile_ssa, 'C0-', lw=2, label='SSA (L=1, n=3)')
axes.set_xlabel(r'$\hat{x}$')
axes.set_ylabel(r'$v_x$ (m/yr)')
axes.set_title('Surface Velocity') 
axes.legend(fontsize=9)
