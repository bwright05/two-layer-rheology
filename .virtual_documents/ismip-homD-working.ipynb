print()
print('-'*70)

print(f'{Lx/1e3:13.0f}', end='', flush=True) #prints the wavelenght/domain 
#max velocities 
nx = min(max(20, int(40 * 80e3 / Lx)), 80)
print(f' {np.max(profile_c_top):13.4f} {np.max(profile_c_bot):8.4f}', end='', flush=True)


